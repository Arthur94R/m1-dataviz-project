    <worksheet name='Top 5 conflits'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Top 5 des conflits les plus longs</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='UCDP_Conflicts_Tableau_Ready' name='federated.17yzhmq0123bj51ey2i421cwlzmp' />
          </datasources>
          <datasource-dependencies datasource='federated.17yzhmq0123bj51ey2i421cwlzmp'>
            <column caption='Label Conflit' datatype='string' name='[Calculation_0326607178493953]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[side_a] + &quot; vs &quot; + [side_b] + &quot; (&quot; + [pays_principal] + &quot;)&quot;' />
            </column>
            <column caption='Duree Conflit' datatype='integer' name='[Calculation_0326607184396291]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[annee_fin] - [annee_debut] + 1' />
            </column>
            <column caption='Annee Debut' datatype='integer' name='[annee_debut]' role='dimension' type='quantitative' />
            <column caption='Annee Fin' datatype='integer' name='[annee_fin]' role='dimension' type='quantitative' />
            <column-instance column='[Calculation_0326607184396291]' derivation='Max' name='[max:Calculation_0326607184396291:qk]' pivot='key' type='quantitative' />
            <column caption='Nb Annees' datatype='integer' name='[nb_annees]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0326607178493953]' derivation='None' name='[none:Calculation_0326607178493953:nk]' pivot='key' type='nominal' />
