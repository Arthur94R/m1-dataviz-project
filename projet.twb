      <aliases enabled='yes' />
      <column caption='Decennie_clean' datatype='string' name='[Calculation_0222016063795201]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR(FLOOR([year] / 10) * 10)' />
      </column>
      <column caption='Adversaire Ukraine Simplifié' datatype='string' name='[Calculation_0222016080510978]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([side_b], &quot;Maidan&quot;) THEN &quot;Manifestants Maïdan (2014)&quot;&#10;ELSEIF CONTAINS([side_b], &quot;Government of Ukraine&quot;) THEN &quot;Russie vs Ukraine (Guerre totale)&quot;&#10;ELSEIF CONTAINS([side_b], &quot;DPR&quot;) AND CONTAINS([side_b], &quot;LPR&quot;) THEN &quot;Séparatistes Donbass (DPR + LPR)&quot;&#10;ELSEIF CONTAINS([side_b], &quot;DPR&quot;) THEN &quot;République de Donetsk (DPR)&quot;&#10;ELSEIF CONTAINS([side_b], &quot;LPR&quot;) THEN &quot;République de Luhansk (LPR)&quot;&#10;ELSEIF CONTAINS([side_b], &quot;Novorossiya&quot;) THEN &quot;Forces de Novorossiya&quot;&#10;ELSE [side_b]&#10;END' />
      </column>
      <column caption='Pays Principal Corrigé' datatype='string' name='[Calculation_0222016082485251]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([location], &quot;Ukraine&quot;) AND CONTAINS([location], &quot;Russia&quot;) THEN &quot;Ukraine&quot;&#10;ELSE SPLIT([location], &apos;,&apos;, 1)&#10;END' />
      </column>
      <column caption='Pays Carte' datatype='string' name='[Calculation_0222016087388164]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
        <calculation class='tableau' formula='IF [conflict_id] = 13243 THEN &quot;Ukraine&quot;&#10;ELSEIF CONTAINS([location], &quot;,&quot;) THEN TRIM(SPLIT([location], &quot;,&quot;, 1))&#10;ELSE [pays_principal]&#10;END' />
      </column>
      <column caption='Conflits depuis 2020' datatype='integer' name='[Calculation_0326607177793536]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [year] &gt;= 2020 THEN [conflict_id] ELSE NULL END' />
      </column>
      <column caption='Label Conflit' datatype='string' name='[Calculation_0326607178493953]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[side_a] + &quot; vs &quot; + [side_b] + &quot; (&quot; + [pays_principal] + &quot;)&quot;' />
      </column>
      <column caption='Duree Conflit' datatype='integer' name='[Calculation_0326607184396291]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[annee_fin] - [annee_debut] + 1' />
      </column>
